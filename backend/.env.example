# ---- LLM Provider Configuration ----
# Choose: "ollama" (local open-source, default), "gemini", or "openai_compatible"
LLM_PROVIDER=ollama

# Ollama (open-source local LLMs e.g. llama3, mistral, qwen2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Google Gemini (optional alt provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Any OpenAI-compatible endpoint (vLLM, LM Studio, Groq, etc.) (optional alt provider)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=not-needed
OPENAI_COMPATIBLE_MODEL=llama-3-8b-instruct

# ---- Vector DB ----
CHROMA_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Web Search (used by Research Agent) ----
ENABLE_WEB_SEARCH=true

# ---- App ----
CORS_ORIGINS=http://localhost:5173
